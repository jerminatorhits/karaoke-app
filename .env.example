# Optional: YouTube Data API key for search. Without it, you can still add songs by pasting URLs.
# Get a key: https://console.cloud.google.com/ → APIs & Services → Enable "YouTube Data API v3" → Create credentials (API key)
VITE_YOUTUBE_API_KEY=your_api_key_here

# Optional: When using remote add, set to the URL where the server is reachable from other devices.
# e.g. BASE_URL=http://192.168.1.5:4000 (your machine's IP on same WiFi) or your deployed URL.
# BASE_URL=http://localhost:4000
